#!/usr/bin/env ruby
# frozen_string_literal: true

require 'yaml'
require 'socket'
require 'optparse'
require 'shellwords'
require 'set'
require 'fileutils'
require 'tmpdir'
require 'timeout'

module Mxup
  VERSION = '0.1.0'
  CONFIG_DIR = File.expand_path('~/.config/mxup')
  RUNTIME_DIR = File.expand_path('~/.local/share/mxup')
  SHELLS = %w[zsh bash sh fish dash].freeze

  class Config
    attr_reader :session, :setup, :windows, :layouts, :layout_names

    def initialize(path)
      raw = YAML.safe_load(File.read(path), permitted_classes: [Symbol])
      @session = raw.fetch('session')
      @setup = raw['setup']&.strip
      @windows = parse_windows(raw.fetch('windows'))
      @layouts, @layout_names = parse_layouts(raw['layouts'])
    end

    def default_layout
      @layout_names.first
    end

    def groups_for(layout_name)
      return [] if layout_name.nil?
      @layouts.fetch(layout_name)
    end

    def effective_window_order(layout_name)
      groups = groups_for(layout_name)
      grouped = groups.flat_map(&:window_names).to_set
      order = []
      groups.each { |g| order << { type: :group, name: g.name, group: g } }
      @windows.each do |w|
        order << { type: :standalone, name: w.name } unless grouped.include?(w.name)
      end
      order
    end

    def window_by_name(name)
      @windows.find { |w| w.name == name }
    end

    def find_group_for_window(layout_name, window_name)
      groups_for(layout_name).each do |g|
        idx = g.window_names.index(window_name)
        return [g, idx] if idx
      end
      nil
    end

    private

    def parse_windows(hash)
      hash.map do |name, opts|
        opts ||= {}
        Window.new(
          name: name,
          root: File.expand_path(opts.fetch('root')),
          command: opts['command']&.strip,
          env: opts['env'] || {},
          wait_for: WaitSpec.parse(opts['wait_for'])
        )
      end
    end

    def parse_layouts(raw)
      return [{}, []] if raw.nil?
      window_names_set = @windows.map(&:name).to_set
      layouts = {}
      order = []

      raw.each do |layout_name, groups_hash|
        order << layout_name
        groups_hash ||= {}
        seen = Set.new
        groups = []

        groups_hash.each do |group_name, group_opts|
          group_opts ||= {}
          pane_names = Array(group_opts['panes'])
          pane_names.each do |pn|
            raise ArgumentError, "Layout '#{layout_name}': window '#{pn}' not found in windows" unless window_names_set.include?(pn)
            raise ArgumentError, "Layout '#{layout_name}': window '#{pn}' appears in multiple groups" if seen.include?(pn)
            seen << pn
          end
          groups << PaneGroup.new(
            name: group_name,
            window_names: pane_names,
            split: group_opts['split'] || 'tiled'
          )
        end

        layouts[layout_name] = groups
      end

      [layouts, order]
    end
  end

  Window = Struct.new(:name, :root, :command, :env, :wait_for, keyword_init: true)
  PaneGroup = Struct.new(:name, :window_names, :split, keyword_init: true)

  WaitSpec = Struct.new(:type, :target, :timeout, :interval, :label, keyword_init: true) do
    CHECK_TYPES = %w[tcp http path script].freeze

    def self.parse(raw)
      case raw
      when String
        new(type: :tcp, target: raw, timeout: nil, interval: 2, label: raw)
      when Hash
        timeout = raw['timeout']
        interval = raw['interval'] || 2
        found = CHECK_TYPES & raw.keys
        raise ArgumentError, "wait_for must specify exactly one of: #{CHECK_TYPES.join(', ')}" unless found.size == 1
        type = found.first
        target = raw[type]
        default_label = type == 'script' ? 'readiness check' : target
        new(type: type.to_sym, target: target, timeout: timeout, interval: interval,
            label: raw['label'] || default_label)
      when nil
        nil
      else
        raise ArgumentError, "wait_for must be a string or hash, got #{raw.class}"
      end
    end
  end

  module Tmux
    module_function

    def has_session?(name)
      system("tmux has-session -t #{esc(name)} 2>/dev/null")
    end

    def session_created(name)
      `tmux display-message -t #{esc(name)} -p '\#{session_created}'`.strip
    end

    def list_windows(session)
      `tmux list-windows -t #{esc(session)} -F '\#{window_index}|\#{window_name}'`
        .strip.split("\n")
        .map { |l| idx, name = l.split('|', 2); { index: idx.to_i, name: name } }
    end

    def list_panes(session)
      `tmux list-panes -t #{esc(session)} -s -F '\#{window_index}|\#{window_name}|\#{pane_index}|\#{pane_pid}|\#{pane_current_path}|\#{pane_current_command}|\#{pane_title}'`
        .strip.split("\n")
        .map do |l|
          win_idx, name, pane_idx, pid, cwd, fg, title = l.split('|', 7)
          { window_index: win_idx.to_i, name: name, pane_index: pane_idx.to_i,
            pid: pid.to_i, cwd: cwd, fg_cmd: fg, title: title.to_s }
        end
    end

    def new_session(name, first_window_name, root)
      system("tmux new-session -d -s #{esc(name)} -n #{esc(first_window_name)} -c #{esc(root)}")
    end

    def new_window(session, name, root)
      system("tmux new-window -t #{esc(session)} -n #{esc(name)} -c #{esc(root)}")
    end

    def split_window(session, window, root, target_pane: nil)
      target = target_pane ? "#{esc(session)}:#{esc(window)}.#{target_pane}" : "#{esc(session)}:#{esc(window)}"
      system("tmux split-window -t #{target} -c #{esc(root)} -d")
    end

    def select_layout(session, window, layout)
      system("tmux select-layout -t #{esc(session)}:#{esc(window)} #{esc(layout)}")
    end

    def join_pane(session, src_window, dst_window)
      system("tmux join-pane -s #{esc(session)}:#{esc(src_window)} -t #{esc(session)}:#{esc(dst_window)} -d")
    end

    def break_pane(session, window, pane_index, new_window_name)
      system("tmux break-pane -s #{esc(session)}:#{esc(window)}.#{pane_index} -n #{esc(new_window_name)} -d")
    end

    def rename_window(session, old_name, new_name)
      system("tmux rename-window -t #{esc(session)}:#{esc(old_name)} #{esc(new_name)}")
    end

    def set_pane_title(session, window, pane_index, title)
      system("tmux select-pane -t #{esc(session)}:#{esc(window)}.#{pane_index} -T #{esc(title)}")
    end

    def set_environment(session, key, value)
      system("tmux set-environment -t #{esc(session)} #{esc(key)} #{esc(value)}")
    end

    def show_environment(session, key)
      out = `tmux show-environment -t #{esc(session)} #{esc(key)} 2>/dev/null`.strip
      return nil if out.empty? || out.start_with?('-')
      out.split('=', 2).last
    end

    def kill_window(session, name)
      system("tmux kill-window -t #{esc(session)}:#{esc(name)}")
    end

    def kill_session(name)
      system("tmux kill-session -t #{esc(name)}")
    end

    def send_keys(session, target, keys)
      system("tmux send-keys -t #{esc(session)}:#{esc(target)} #{esc(keys)} Enter")
    end

    def send_interrupt(session, target)
      system("tmux send-keys -t #{esc(session)}:#{esc(target)} C-c")
    end

    def pane_target(window, pane_index)
      "#{window}.#{pane_index}"
    end

    def move_window(session, src_name, dst_index)
      system("tmux move-window -s #{esc(session)}:#{esc(src_name)} -t #{esc(session)}:#{dst_index} 2>/dev/null")
    end

    def swap_window(session, idx_a, idx_b)
      system("tmux swap-window -s #{esc(session)}:#{idx_a} -t #{esc(session)}:#{idx_b}")
    end

    # Capture the pane's full scrollback (all history tmux still has) plus the
    # visible screen. The caller is responsible for picking the tail it wants.
    # We deliberately don't bound the start at -lines, because if the process
    # printed its interesting output early and has been idle since, -S -lines
    # would only see blank prompt padding and miss the real content.
    def capture_pane(session, target, _lines = nil)
      `tmux capture-pane -t #{esc(session)}:#{esc(target)} -p -S - 2>/dev/null`
    end

    def pane_count(session, window)
      `tmux list-panes -t #{esc(session)}:#{esc(window)} 2>/dev/null`.strip.split("\n").size
    end

    def esc(val)
      Shellwords.escape(val.to_s)
    end
  end

  class Runner
    def initialize(config, dry_run: false, layout: nil)
      @config = config
      @dry_run = dry_run
      @session = config.session
      @requested_layout = layout
    end

    def up
      if Tmux.has_session?(@session)
        reconcile
      else
        create_fresh
      end
    end

    def status(lines:)
      unless Tmux.has_session?(@session)
        puts "SESSION: #{@session} — NOT RUNNING"
        puts "Start with: mxup up #{@session}"
        return
      end

      created = Tmux.session_created(@session)
      ts = Time.at(created.to_i).strftime('%Y-%m-%d %H:%M:%S')
      active = active_layout_name
      layout_info = active ? " (layout: #{active})" : ''
      puts "SESSION: #{@session} — up since #{ts}#{layout_info}"
      puts

      panes = Tmux.list_panes(@session)
      groups = active ? @config.groups_for(active) : []
      group_map = {}
      groups.each { |g| g.window_names.each_with_index { |wn, i| group_map[wn] = [g, i] } }
      declared_names = @config.windows.map(&:name)

      printed_windows = Set.new
      effective_order = @config.effective_window_order(active)

      effective_order.each do |entry|
        if entry[:type] == :group
          group = entry[:group]
          group_panes = panes.select { |p| p[:name] == group.name }
            .sort_by { |p| p[:pane_index] }

          if group_panes.empty?
            group.window_names.each { |wn| puts "[?] #{wn}  MISSING (group: #{group.name})"; puts }
            next
          end

          puts "[#{group_panes.first[:window_index]}] #{group.name} (#{group.window_names.join(', ')})  split=#{group.split}"

          group.window_names.each_with_index do |wn, idx|
            printed_windows << wn
            pane = group_panes.find { |p| p[:title] == wn } ||
                   group_panes.find { |p| p[:pane_index] == idx }
            if pane.nil?
              puts "  #{wn}: MISSING"
              next
            end
            puts "  #{wn}:"
            print_pane_status(pane, wn, lines, indent: '    ')
          end
          puts

        else
          wn = entry[:name]
          printed_windows << wn
          pane = panes.find { |p| p[:name] == wn && p[:pane_index] == 0 }
          if pane.nil?
            puts "[?] #{wn}  MISSING"
            puts
            next
          end

          tag = declared_names.include?(pane[:name]) ? '' : ' [NOT IN CONFIG]'
          puts "[#{pane[:window_index]}] #{pane[:name]}#{tag}"
          print_pane_status(pane, wn, lines, indent: '    ')
          puts
        end
      end

      panes.each do |pane|
        logical = pane[:title].to_s.empty? ? pane[:name] : pane[:title]
        next if printed_windows.include?(logical) || printed_windows.include?(pane[:name])
        puts "[#{pane[:window_index]}] #{pane[:name]} [NOT IN CONFIG]"
        print_pane_status(pane, pane[:name], lines, indent: '    ')
        puts
      end
    end

    def down
      if Tmux.has_session?(@session)
        if @dry_run
          puts "[dry-run] Would gracefully stop session #{@session}"
        else
          graceful_stop
          Tmux.kill_session(@session)
          cleanup_runtime_dir
          puts "Session #{@session} killed."
        end
      else
        puts "Session #{@session} is not running."
      end
    end

    def restart(window_names)
      abort "Session #{@session} is not running." unless Tmux.has_session?(@session)
      write_launcher_scripts

      targets = if window_names.nil? || window_names.empty?
                  @config.windows
                else
                  window_names.flat_map { |n| n.split(',') }.map do |n|
                    @config.windows.find { |w| w.name == n } ||
                      abort("Window '#{n}' not found in config.")
                  end
                end

      active = active_layout_name

      targets.each do |win|
        target_ref = resolve_pane_target(win.name, active)
        if target_ref
          if @dry_run
            puts "[dry-run] Would restart #{win.name}"
          else
            Tmux.send_interrupt(@session, target_ref)
            sleep 1
            Tmux.send_interrupt(@session, target_ref)
            sleep 1
            Tmux.send_keys(@session, target_ref, assemble_command(win))
            puts "  #{win.name}: restarted"
          end
        else
          if @dry_run
            puts "[dry-run] Would create #{win.name}"
          else
            create_standalone_window(win)
            puts "  #{win.name}: created"
          end
        end
      end
    end

    def switch_layout(target_layout)
      abort "Session #{@session} is not running." unless Tmux.has_session?(@session)
      abort "Layout '#{target_layout}' not found in config. Available: #{@config.layout_names.join(', ')}" \
        unless @config.layout_names.include?(target_layout)

      current = stored_layout_name

      if current == target_layout
        puts "Already using layout '#{target_layout}'."
        return
      end

      if @dry_run
        puts "[dry-run] Would switch layout from '#{current}' to '#{target_layout}'"
        return
      end

      puts "Switching layout: #{current || 'none'} → #{target_layout}..."

      flatten_to_standalone
      apply_layout(target_layout)
      reorder_windows
      Tmux.set_environment(@session, 'MXUP_LAYOUT', target_layout)

      puts "Layout switched to '#{target_layout}'."
    end

    def target(window_names)
      abort "Session #{@session} is not running." unless Tmux.has_session?(@session)
      layout = active_layout_name

      requested = Array(window_names).flat_map { |n| n.split(',') }.reject(&:empty?)

      if requested.empty?
        @config.windows.each do |win|
          t = resolve_pane_target(win.name, layout)
          if t
            puts "#{win.name}\t#{@session}:#{t}"
          else
            puts "#{win.name}\t(not running)"
          end
        end
      else
        requested.each do |wn|
          @config.windows.find { |w| w.name == wn } ||
            abort("Window '#{wn}' not found in config.")
          t = resolve_pane_target(wn, layout)
          abort("Window '#{wn}' is not currently in the session.") unless t
          if requested.size == 1
            puts "#{@session}:#{t}"
          else
            puts "#{wn}\t#{@session}:#{t}"
          end
        end
      end
    end

    # Run a command in a specific pane, wait for it to finish, capture output.
    #
    # Replaces the verbose pattern:
    #   MARKER="..."; tmux send-keys -t X "cmd; tmux wait-for -S $MARKER" Enter \
    #     && tmux wait-for $MARKER; tmux capture-pane -t X -p -S -50
    #
    # target_spec may be:
    #   - "session:window"       (session must match config)
    #   - "window"               (logical name from config, or a raw tmux window)
    #   - "window.pane_index"    (raw tmux pane address)
    def exec(target_spec, command, lines: 50, timeout: nil, force: false, quiet: false)
      abort "Session #{@session} is not running." unless Tmux.has_session?(@session)
      abort 'mxup exec: command is required.' if command.nil? || command.strip.empty?

      window_part = if target_spec.include?(':')
                      sess, rest = target_spec.split(':', 2)
                      abort "Target session '#{sess}' does not match config session '#{@session}'." if sess != @session
                      rest
                    else
                      target_spec
                    end

      resolved = resolve_exec_target(window_part)
      abort "Target '#{window_part}' not found in session '#{@session}'." unless resolved
      full_target = "#{@session}:#{resolved}"

      unless force
        pane = pane_for_target(resolved)
        if pane && !SHELLS.include?(pane[:fg_cmd])
          abort "Target pane #{full_target} is busy (#{pane[:fg_cmd]}). Pass --force to send anyway."
        end
      end

      if @dry_run
        puts "[dry-run] Would exec on #{full_target}: #{command}"
        return 0
      end

      marker = "mxup-exec-#{Process.pid}-#{Time.now.to_i}-#{rand(10**9)}"
      exit_file = File.join(Dir.tmpdir, "#{marker}.rc")
      FileUtils.rm_f(exit_file)

      cmd_clean = command.strip.sub(/;+\s*\z/, '')
      # Wrap in a subshell so `exit N` or `set -e` inside the user command
      # can't kill the pane's interactive shell and strand us waiting for
      # the marker.
      wrapped = "( #{cmd_clean} ); __mxup_rc=$?; echo $__mxup_rc > #{Shellwords.escape(exit_file)}; tmux wait-for -S #{Shellwords.escape(marker)}"

      unless system("tmux send-keys -t #{Tmux.esc(full_target)} #{Shellwords.escape(wrapped)} Enter")
        abort "Failed to send command to #{full_target}."
      end

      timed_out = wait_for_marker(marker, timeout)

      output = `tmux capture-pane -t #{Tmux.esc(full_target)} -p -S -#{lines.to_i}`
      unless quiet
        print output
        puts unless output.end_with?("\n")
      end

      if timed_out
        warn "[mxup] exec: timed out after #{timeout}s waiting for command on #{full_target}."
        FileUtils.rm_f(exit_file)
        exit 124
      end

      rc = read_exit_code(exit_file)
      FileUtils.rm_f(exit_file)
      exit(rc || 0)
    end

    def show_layouts
      active = Tmux.has_session?(@session) ? active_layout_name : nil
      if @config.layout_names.empty?
        puts "No layouts defined in config."
        return
      end
      puts "Available layouts:"
      @config.layout_names.each do |name|
        marker = name == active ? ' (active)' : ''
        groups = @config.groups_for(name)
        if groups.empty?
          puts "  #{name}#{marker}: flat (all standalone)"
        else
          group_desc = groups.map { |g| "#{g.name}=[#{g.window_names.join(',')}]" }.join(', ')
          puts "  #{name}#{marker}: #{group_desc}"
        end
      end
    end

    private

    def active_layout_name
      if @requested_layout
        @requested_layout
      elsif Tmux.has_session?(@session)
        stored = Tmux.show_environment(@session, 'MXUP_LAYOUT')
        stored && @config.layout_names.include?(stored) ? stored : @config.default_layout
      else
        @config.default_layout
      end
    end

    def stored_layout_name
      if Tmux.has_session?(@session)
        stored = Tmux.show_environment(@session, 'MXUP_LAYOUT')
        stored && @config.layout_names.include?(stored) ? stored : @config.default_layout
      else
        @config.default_layout
      end
    end

    def resolve_exec_target(window_part)
      layout = active_layout_name

      if @config.windows.any? { |w| w.name == window_part }
        resolved = resolve_pane_target(window_part, layout)
        return resolved if resolved
      end

      if window_part =~ /\A(.+)\.\d+\z/
        return window_part if Tmux.list_windows(@session).map { |w| w[:name] }.include?(Regexp.last_match(1))
      end

      existing = Tmux.list_windows(@session).map { |w| w[:name] }
      return window_part if existing.include?(window_part)

      nil
    end

    def pane_for_target(target)
      if target =~ /\A(.+)\.(\d+)\z/
        win_name = Regexp.last_match(1)
        pane_idx = Regexp.last_match(2).to_i
        Tmux.list_panes(@session).find { |p| p[:name] == win_name && p[:pane_index] == pane_idx }
      else
        Tmux.list_panes(@session).find { |p| p[:name] == target && p[:pane_index] == 0 }
      end
    end

    def wait_for_marker(marker, timeout)
      if timeout.nil?
        system("tmux wait-for #{Tmux.esc(marker)}")
        return false
      end

      pid = Process.spawn("tmux wait-for #{Tmux.esc(marker)}")
      begin
        Timeout.timeout(timeout) { Process.waitpid(pid) }
        false
      rescue Timeout::Error
        begin
          Process.kill('TERM', pid)
        rescue StandardError
        end
        begin
          Process.waitpid(pid)
        rescue StandardError
        end
        # Release any other waiters on this marker.
        system("tmux wait-for -S #{Tmux.esc(marker)} 2>/dev/null")
        true
      end
    end

    def read_exit_code(path)
      return nil unless File.exist?(path)
      val = File.read(path).strip
      val.empty? ? nil : val.to_i
    end

    def resolve_pane_target(window_name, layout_name)
      result = @config.find_group_for_window(layout_name, window_name)
      if result
        group, config_idx = result
        existing = Tmux.list_windows(@session).map { |w| w[:name] }
        return nil unless existing.include?(group.name)
        pane = Tmux.list_panes(@session)
          .find { |p| p[:name] == group.name && p[:title] == window_name }
        actual_idx = pane ? pane[:pane_index] : config_idx
        Tmux.pane_target(group.name, actual_idx)
      else
        existing = Tmux.list_windows(@session).map { |w| w[:name] }
        return nil unless existing.include?(window_name)
        window_name
      end
    end

    def graceful_stop(timeout: 30)
      puts "Stopping session #{@session}..."
      deadline = Time.now + timeout
      round = 0

      loop do
        break unless Tmux.has_session?(@session)

        panes = Tmux.list_panes(@session)
        busy = panes.reject { |p| SHELLS.include?(p[:fg_cmd]) }
        break if busy.empty?

        if round > 0
          remaining = (deadline - Time.now).ceil
          puts "  waiting... #{busy.size} process#{'es' unless busy.size == 1} still running (#{remaining}s left)"
        end

        busy.each do |pane|
          target = Tmux.pane_target(pane[:name], pane[:pane_index])
          Tmux.send_interrupt(@session, target)
        end

        if Time.now >= deadline
          names = busy.map { |p| p[:title].to_s.empty? ? p[:name] : p[:title] }.uniq
          warn "  timeout: #{names.join(', ')} did not exit in #{timeout}s — killing anyway"
          break
        end

        round += 1
        sleep 1
      end
    end

    def create_fresh
      puts "Creating session #{@session}..."
      write_launcher_scripts
      layout = active_layout_name
      order = @config.effective_window_order(layout)

      if @dry_run
        order.each do |entry|
          if entry[:type] == :group
            puts "[dry-run] Would create pane group: #{entry[:name]} (#{entry[:group].window_names.join(', ')})"
          else
            puts "[dry-run] Would create window: #{entry[:name]}"
          end
        end
        return
      end

      first_entry = order.first
      if first_entry[:type] == :group
        group = first_entry[:group]
        first_win = @config.window_by_name(group.window_names.first)
        Tmux.new_session(@session, group.name, first_win.root)
        setup_pane_group_in_existing_window(group)
        puts "  #{group.name}: created (#{group.window_names.join(', ')})"
      else
        win = @config.window_by_name(first_entry[:name])
        Tmux.new_session(@session, win.name, win.root)
        Tmux.set_pane_title(@session, win.name, 0, win.name)
        Tmux.send_keys(@session, win.name, assemble_command(win))
        puts "  #{win.name}: created"
      end

      order.drop(1).each do |entry|
        if entry[:type] == :group
          create_pane_group(entry[:group])
          puts "  #{entry[:name]}: created (#{entry[:group].window_names.join(', ')})"
        else
          win = @config.window_by_name(entry[:name])
          create_standalone_window(win)
          puts "  #{win.name}: created"
        end
      end

      if layout
        Tmux.set_environment(@session, 'MXUP_LAYOUT', layout)
      end

      puts "Session #{@session} is up (#{@config.windows.size} windows)."
    end

    def reconcile
      puts "Reconciling session #{@session}..."
      write_launcher_scripts
      layout = active_layout_name
      stored = Tmux.show_environment(@session, 'MXUP_LAYOUT')

      if layout && stored && stored != layout
        switch_layout(layout)
      end

      existing = Tmux.list_panes(@session)
      existing_win_names = Tmux.list_windows(@session).map { |w| w[:name] }
      order = @config.effective_window_order(layout)

      expected_tmux_windows = order.map { |e| e[:name] }.to_set
      extras = existing_win_names.reject { |n| expected_tmux_windows.include?(n) }
      extras.each do |name|
        if @dry_run
          puts "  [dry-run] Would remove extra window: #{name}"
        else
          warn "  #{name}: not in config — removing"
          Tmux.kill_window(@session, name)
        end
      end

      order.each do |entry|
        if entry[:type] == :group
          reconcile_group(entry[:group], existing, existing_win_names)
        else
          reconcile_standalone(entry[:name], existing, existing_win_names)
        end
      end

      reorder_windows
      if layout
        Tmux.set_environment(@session, 'MXUP_LAYOUT', layout)
      end
      puts 'Reconciliation complete.'
    end

    def reconcile_group(group, existing_panes, existing_win_names)
      unless existing_win_names.include?(group.name)
        if @dry_run
          puts "  [dry-run] Would create pane group: #{group.name}"
        else
          create_pane_group(group)
          puts "  #{group.name}: created (#{group.window_names.join(', ')})"
        end
        return
      end

      current_count = Tmux.pane_count(@session, group.name)
      expected_count = group.window_names.size

      if current_count != expected_count
        if @dry_run
          puts "  [dry-run] Would recreate pane group: #{group.name} (pane count #{current_count} != #{expected_count})"
        else
          Tmux.kill_window(@session, group.name)
          create_pane_group(group)
          puts "  #{group.name}: recreated (pane count changed)"
        end
        return
      end

      group_panes = existing_panes.select { |p| p[:name] == group.name }
        .sort_by { |p| p[:pane_index] }

      group.window_names.each_with_index do |wn, idx|
        win = @config.window_by_name(wn)
        pane = group_panes.find { |p| p[:title] == wn } ||
               group_panes.find { |p| p[:pane_index] == idx }
        next unless pane

        actual_idx = pane[:pane_index]
        target = Tmux.pane_target(group.name, actual_idx)
        if SHELLS.include?(pane[:fg_cmd])
          if @dry_run
            puts "  [dry-run] Would restart idle pane: #{wn} in #{group.name}"
          else
            Tmux.send_keys(@session, target, assemble_command(win))
            puts "  #{wn}: restarted (was idle) [#{group.name}.#{actual_idx}]"
          end
        else
          puts "  #{wn}: running (#{pane[:fg_cmd]}) — ok [#{group.name}.#{actual_idx}]"
        end
      end
    end

    def reconcile_standalone(window_name, existing_panes, existing_win_names)
      win = @config.window_by_name(window_name)
      pane = existing_panes.find { |p| p[:name] == window_name }

      if pane.nil?
        if @dry_run
          puts "  [dry-run] Would create missing window: #{window_name}"
        else
          create_standalone_window(win)
          puts "  #{window_name}: created (was missing)"
        end
      elsif SHELLS.include?(pane[:fg_cmd])
        if @dry_run
          puts "  [dry-run] Would restart idle window: #{window_name}"
        else
          Tmux.send_keys(@session, window_name, assemble_command(win))
          puts "  #{window_name}: restarted (was idle)"
        end
      else
        puts "  #{window_name}: running (#{pane[:fg_cmd]}) — ok"
      end
    end

    def create_pane_group(group)
      first_win = @config.window_by_name(group.window_names.first)
      Tmux.new_window(@session, group.name, first_win.root)
      setup_pane_group_in_existing_window(group)
    end

    def setup_pane_group_in_existing_window(group)
      group.window_names.drop(1).each_with_index do |wn, i|
        win = @config.window_by_name(wn)
        Tmux.split_window(@session, group.name, win.root, target_pane: i)
      end

      Tmux.select_layout(@session, group.name, group.split)

      group.window_names.each_with_index do |wn, idx|
        win = @config.window_by_name(wn)
        Tmux.set_pane_title(@session, group.name, idx, win.name)
        Tmux.send_keys(@session, Tmux.pane_target(group.name, idx), assemble_command(win))
      end
    end

    def create_standalone_window(win)
      Tmux.new_window(@session, win.name, win.root)
      Tmux.set_pane_title(@session, win.name, 0, win.name)
      Tmux.send_keys(@session, win.name, assemble_command(win))
    end

    def flatten_to_standalone
      panes = Tmux.list_panes(@session)
      windows_with_multi_panes = panes.group_by { |p| p[:name] }
        .select { |_, ps| ps.size > 1 }

      windows_with_multi_panes.each do |win_name, win_panes|
        sorted = win_panes.sort_by { |p| p[:pane_index] }.reverse
        sorted.each do |pane|
          next if pane[:pane_index] == 0
          logical_name = pane[:title].to_s.empty? ? "#{win_name}_#{pane[:pane_index]}" : pane[:title]
          Tmux.break_pane(@session, win_name, pane[:pane_index], logical_name)
        end
        first_pane = sorted.last
        first_logical = first_pane[:title].to_s.empty? ? win_name : first_pane[:title]
        Tmux.rename_window(@session, win_name, first_logical) if first_logical != win_name
      end
    end

    def apply_layout(layout_name)
      groups = @config.groups_for(layout_name)
      groups.each do |group|
        next if group.window_names.size < 2

        first_wn = group.window_names.first
        Tmux.rename_window(@session, first_wn, group.name)

        group.window_names.drop(1).each do |wn|
          Tmux.join_pane(@session, wn, group.name)
        end

        group.window_names.each_with_index do |wn, idx|
          Tmux.set_pane_title(@session, group.name, idx, wn)
        end
        Tmux.select_layout(@session, group.name, group.split)
      end

      groups.select { |g| g.window_names.size == 1 }.each do |group|
        wn = group.window_names.first
        Tmux.rename_window(@session, wn, group.name)
        Tmux.set_pane_title(@session, group.name, 0, wn)
      end
    end

    def assemble_command(win)
      has_content = (@config.setup && !@config.setup.empty?) ||
                    win.wait_for ||
                    win.env.any? ||
                    (win.command && !win.command.empty?)
      return '' unless has_content
      ". #{launcher_script_path(win.name)}"
    end

    def session_runtime_dir
      File.join(RUNTIME_DIR, @session)
    end

    def launcher_script_path(window_name)
      File.join(session_runtime_dir, "#{window_name}_launcher.sh")
    end

    def write_launcher_scripts
      dir = session_runtime_dir
      FileUtils.mkdir_p(dir)

      @config.windows.each do |win|
        has_content = (@config.setup && !@config.setup.empty?) ||
                      win.wait_for ||
                      win.env.any? ||
                      (win.command && !win.command.empty?)
        next unless has_content
        path = launcher_script_path(win.name)
        File.write(path, generate_launcher_script(win))
        File.chmod(0o755, path)
      end
    end

    def cleanup_runtime_dir
      dir = session_runtime_dir
      FileUtils.rm_rf(dir) if Dir.exist?(dir)
    end

    def generate_launcher_script(win)
      lines = []
      lines << "# mxup launcher for #{win.name}"
      lines << "cd #{Shellwords.escape(win.root)}"

      if @config.setup && !@config.setup.empty?
        lines << ""
        @config.setup.split("\n").each { |l| lines << l }
      end

      if win.wait_for
        lines << ""
        lines.concat(generate_wait_block(win.name, win.wait_for))
      end

      if win.env.any?
        lines << ""
        win.env.each { |k, v| lines << "export #{k}=#{Shellwords.escape(v)}" }
      end

      if win.command && !win.command.empty?
        lines << ""
        lines << win.command
      end

      lines.join("\n") + "\n"
    end

    def generate_wait_block(window_name, spec)
      check_cmd = case spec.type
                  when :tcp
                    host, port = spec.target.split(':', 2)
                    "nc -z #{host} #{port} 2>/dev/null"
                  when :http
                    "curl -sf #{Shellwords.escape(spec.target)} >/dev/null 2>&1"
                  when :path
                    "[ -e #{Shellwords.escape(spec.target)} ]"
                  when :script
                    spec.target
                  end

      lines = []
      lines << "echo 'Waiting for #{spec.label}...'"
      lines << "_mxup_wait_start=$(date +%s)"
      lines << ""

      if spec.timeout
        lines << "until #{check_cmd}; do"
        lines << "  _mxup_elapsed=$(($(date +%s) - _mxup_wait_start))"
        lines << "  if [ \"$_mxup_elapsed\" -ge #{spec.timeout.to_i} ]; then"
        lines << "    echo 'Timed out waiting for #{spec.label} after #{spec.timeout.to_i}s' >&2"
        lines << "    break"
        lines << "  fi"
        lines << "  echo \"  still waiting... (${_mxup_elapsed}s of #{spec.timeout.to_i}s)\""
        lines << "  sleep #{spec.interval}"
        lines << "done"
      else
        lines << "until #{check_cmd}; do"
        lines << "  echo \"  still waiting... ($(($(date +%s) - _mxup_wait_start))s)\""
        lines << "  sleep #{spec.interval}"
        lines << "done"
      end

      lines << ""
      lines << "echo '#{spec.label} is ready.'"
      lines
    end

    def reorder_windows
      return if @dry_run

      layout = active_layout_name
      order = @config.effective_window_order(layout)
      names = order.map { |e| e[:name] }

      names.each_with_index do |name, i|
        cur = Tmux.list_windows(@session).find { |w| w[:name] == name }
        next unless cur
        Tmux.move_window(@session, name, 900 + i)
      end

      names.each_with_index do |name, target_idx|
        Tmux.move_window(@session, name, target_idx)
      end
    end

    def print_pane_status(pane, logical_name, lines, indent: '    ')
      idle = SHELLS.include?(pane[:fg_cmd])
      status_str = if idle
                     "IDLE (shell: #{pane[:fg_cmd]}, pid=#{pane[:pid]})"
                   else
                     leaf = find_leaf(pane[:pid])
                     cmd = ps_field(leaf, 'args') || pane[:fg_cmd]
                     elapsed = ps_field(leaf, 'etime')&.strip || '?'
                     started = ps_field(leaf, 'lstart') || '?'
                     "RUNNING  pid=#{leaf}  elapsed=#{elapsed}  fg=#{pane[:fg_cmd]}\n" \
                     "#{indent}command: #{cmd}\n" \
                     "#{indent}started: #{started}"
                   end

      in_group = pane[:name] != logical_name
      target = in_group ? Tmux.pane_target(pane[:name], pane[:pane_index]) : pane[:name]
      puts "#{indent}target: #{@session}:#{target}"
      puts "#{indent}cwd: #{pane[:cwd]}"
      puts "#{indent}#{status_str}"

      output = Tmux.capture_pane(@session, target)
        .split("\n").reject { |l| l.strip.empty? }.last(lines)
      unless output.empty?
        puts "#{indent}--- last output (up to #{lines} lines) ---"
        output.each { |l| puts "#{indent}#{l}" }
        puts "#{indent}---"
      end
    end

    def find_leaf(pid)
      current = pid
      loop do
        child = `pgrep -P #{current} 2>/dev/null`.strip.split("\n").first
        break unless child && !child.empty?
        current = child.to_i
      end
      current
    end

    def ps_field(pid, field)
      val = `ps -p #{pid} -o #{field}= 2>/dev/null`.strip
      val.empty? ? nil : val
    end
  end

  class CLI
    def run(argv)
      args = argv.dup
      options = { dry_run: false, config: nil, lines: nil, layout: nil,
                  target: nil, timeout: nil, force: false, quiet: false }

      parser = OptionParser.new do |opts|
        opts.banner = "Usage: mxup [command] [name] [options]"
        opts.on('-f', '--file FILE', 'Config file path') { |f| options[:config] = f }
        opts.on('--dry-run', 'Preview changes without applying') { options[:dry_run] = true }
        opts.on('--lines N', Integer, 'Output lines (status/exec)') { |n| options[:lines] = n }
        opts.on('--layout NAME', 'Layout to use (for up/layout commands)') { |l| options[:layout] = l }
        opts.on('-t', '--target TARGET', 'Target window/pane for exec (e.g. name:window)') { |t| options[:target] = t }
        opts.on('--timeout N', Integer, 'Timeout in seconds (for exec)') { |n| options[:timeout] = n }
        opts.on('--force', 'Force exec on a busy pane') { options[:force] = true }
        opts.on('-q', '--quiet', 'Suppress captured output (for exec)') { options[:quiet] = true }
        opts.on('-v', '--version', 'Show version') { puts "mxup #{VERSION}"; exit }
        opts.on('-h', '--help', 'Show help') { puts opts; exit }
      end

      parser.parse!(args)

      command = 'up'
      if args.first && !args.first.include?('.yml') && !args.first.include?('/')
        maybe_cmd = args.first
        if %w[up status down restart layout target exec].include?(maybe_cmd)
          command = args.shift
        end
      end

      case command
      when 'restart', 'target'
        spec = args.shift
        if spec&.include?(':')
          name, windows_str = spec.split(':', 2)
          window_names = windows_str ? windows_str.split(',') : []
        elsif spec
          candidate = File.join(CONFIG_DIR, "#{spec}.yml")
          if File.exist?(candidate) || (options[:config] && spec !~ /,/)
            name = spec
            window_names = args
          else
            name = nil
            window_names = [spec] + args
          end
        else
          name = nil
          window_names = []
        end
        config = load_config(options[:config], name)
        runner = Runner.new(config, dry_run: options[:dry_run], layout: options[:layout])
        if command == 'restart'
          runner.restart(window_names)
        else
          runner.target(window_names)
        end

      when 'layout'
        name = args.shift
        target_layout = args.shift
        config = load_config(options[:config], name)
        runner = Runner.new(config, dry_run: options[:dry_run], layout: options[:layout])
        if target_layout
          runner.switch_layout(target_layout)
        else
          runner.show_layouts
        end

      when 'exec'
        target = options[:target] || args.shift
        abort 'Usage: mxup exec -t [name:]WINDOW "command"' if target.nil? || target.empty?
        command_str = args.shift
        abort 'Usage: mxup exec -t [name:]WINDOW "command"' if command_str.nil?

        name = target.include?(':') ? target.split(':', 2).first : nil
        config = load_config(options[:config], name)
        runner = Runner.new(config, dry_run: options[:dry_run], layout: options[:layout])
        runner.exec(target, command_str,
                    lines: options[:lines] || 50,
                    timeout: options[:timeout],
                    force: options[:force],
                    quiet: options[:quiet])

      when 'up', 'status', 'down'
        name = args.shift
        config = load_config(options[:config], name)
        runner = Runner.new(config, dry_run: options[:dry_run], layout: options[:layout])

        case command
        when 'up'     then runner.up
        when 'status' then runner.status(lines: options[:lines] || 2)
        when 'down'   then runner.down
        end

      else
        abort "Unknown command: #{command}. Use: up, status, down, restart, layout, target, exec"
      end
    end

    private

    def load_config(explicit_path, name)
      path = resolve_config(explicit_path, name)
      abort "Config not found. Provide -f path or place config in #{CONFIG_DIR}/" unless path
      Config.new(path)
    end

    def resolve_config(explicit, name)
      return explicit if explicit && File.exist?(explicit)

      if name
        candidate = File.join(CONFIG_DIR, "#{name}.yml")
        return candidate if File.exist?(candidate)
      end

      local = File.join(Dir.pwd, 'mxup.yml')
      return local if File.exist?(local)

      if Dir.exist?(CONFIG_DIR)
        configs = Dir.glob(File.join(CONFIG_DIR, '*.yml'))
        return configs.first if configs.size == 1
      end

      nil
    end
  end
end

Mxup::CLI.new.run(ARGV) if __FILE__ == $PROGRAM_NAME
